#!/bin/bash

# Add repo helper scripts and ~/.local/bin to PATH.
export PATH="$HOME/.dotfiles/links/bin:$HOME/.local/bin:$PATH"

# Ensure ~/.docker exists so that `az acr login` can write credentials to
# ~/.docker/config.json without failing with DOCKER_COMMAND_ERROR.
mkdir -p "$HOME/.docker"

# MCP server config: VS Code's remote user config is the source of truth
# (maintained via Settings Sync). Point Agency Copilot at the same file so
# both tools share one config. Note: on a fresh devbox, this symlink is
# dangling until you open a remote VS Code window at least once.
if [ ! -L "$HOME/.copilot/mcp-config.json" ]; then
  mkdir -p "$HOME/.copilot"
  ln -sf "$HOME/.vscode-server/data/User/mcp.json" "$HOME/.copilot/mcp-config.json"
fi
