#!/bin/bash

# Add repo helper scripts and ~/.local/bin to PATH.
export PATH="$HOME/.dotfiles/links/bin:$HOME/.local/bin:$PATH"

# Ensure ~/.docker exists so that `az acr login` can write credentials to
# ~/.docker/config.json without failing with DOCKER_COMMAND_ERROR.
mkdir -p "$HOME/.docker"

# Agency Copilot MCP server config. VS Code does not need this (a remote
# window inherits mcp.json from the Windows client), but Agency Copilot
# reads ~/.copilot/mcp-config.json directly from disk, so we maintain a
# dedicated dotfiles-tracked copy for it.
if [ ! -L "$HOME/.copilot/mcp-config.json" ]; then
  mkdir -p "$HOME/.copilot"
  ln -sf "$HOME/.dotfiles/links/copilot-mcp-config.json" "$HOME/.copilot/mcp-config.json"
fi
