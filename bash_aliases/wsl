# WSL specific file structure
alias cdrjs='cd /mnt/c/Users/robstarling'
# alias cdone='cd ~/one'

# Automatically start npiperelay and socat to help bridge the Windows named pipe 
# used by the SSH agent to a Unix socket that WSL2 can use.
#
# npiperelay.exe:
#  - can also be downloaded from jstarks/npiperelay releases, or 
#  - build with Go (on Windows): go install github.com/jstarks/npiperelay@latest
export SSH_AUTH_SOCK=$HOME/.ssh-agent.sock
rm -f "$SSH_AUTH_SOCK"
(setsid socat UNIX-LISTEN:"$SSH_AUTH_SOCK",fork EXEC:"$HOME/.dotfiles/src/npiperelay.exe -ei -s //./pipe/openssh-ssh-agent",nofork &) >/dev/null 2>&1
