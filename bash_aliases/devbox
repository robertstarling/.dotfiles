#!/bin/bash

# Add ~/nc-devbox PATH; this contains various useful scripts from the devbox CLI
export PATH="$HOME/nc-devbox:$PATH"

# Add ~/.local/bin to PATH; this is where pipx installs binaries
export PATH="$PATH:$HOME/.local/bin"

# Ensure azureauth wrapper is linked (azureauth fails in headless SSH sessions;
# the wrapper delegates to az cli instead). See: ~/.dotfiles/links/bin/azureauth
if [ ! -L "$HOME/.local/bin/azureauth" ]; then
  mkdir -p "$HOME/.local/bin"
  ln -sf "$HOME/.dotfiles/links/bin/azureauth" "$HOME/.local/bin/azureauth"
fi

# Global MCP server config: single source of truth in dotfiles, symlinked for
# both Agency Copilot (~/.copilot/mcp-config.json) and VS Code (.vscode/mcp.json).
if [ ! -L "$HOME/.copilot/mcp-config.json" ]; then
  mkdir -p "$HOME/.copilot"
  ln -sf "$HOME/.dotfiles/links/mcp.json" "$HOME/.copilot/mcp-config.json"
fi

# Show current janitor TTL when we log in
devboxRG="robstarling-2509"
devboxSub="ba2d1b49-6fc3-4223-bd59-0ba7878b5fb3"
janitor $devboxRG $devboxSub
echo "To extend Janitor TTL for $devboxRG $devboxSub:"
echo "janitor_reset \$devboxRG \$devboxSub"

# Reset janitor tag on the devbox resource group whenever we log into azure to prevent automated cleanup while the devbox is in use.
alias azl='azure_login && janitor_reset $devboxRG $devboxSub'
