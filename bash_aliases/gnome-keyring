#!/bin/bash

# Start GNOME Keyring daemon for secure credential storage (e.g. Copilot CLI tokens).
# Requires: gnome-keyring libsecret-1-0 dbus-x11 (installed by setup-nc-devbox.sh)

if [ -z "$DBUS_SESSION_BUS_ADDRESS" ] && command -v dbus-launch >/dev/null 2>&1; then
  eval "$(dbus-launch --sh-syntax)"
fi
if command -v gnome-keyring-daemon >/dev/null 2>&1; then
  if keyring_output="$(gnome-keyring-daemon --start --components=secrets)"; then
    eval "$keyring_output"
  fi
fi
export GNOME_KEYRING_CONTROL
